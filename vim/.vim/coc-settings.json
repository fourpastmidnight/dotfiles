{
    "languageserver": {
        "haskell": {
            "command": "haskell-language-server-wrapper",
            "args": ["--lsp"],
            "rootPatterns": [
                "*.cabal",
                "stack.yaml",
                "cabal.project",
                "package.yaml",
                "hie.yaml",
                "BUILD.bazel"
            ],
            "filetypes": ["haskell", "lhaskell", "hs", "lhs"],
            "initializationOptions": {
                "languageServerHaskell": {
                    "hlintOn": true,
                    "completionSnippetsOn": true
                }
            }
        }
    }
}
