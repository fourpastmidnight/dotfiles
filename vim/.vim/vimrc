" Vimrc
"
" Shamelessly borrowed from https://github.com/christoomey/dotfiles/blob/master/vim/vimrc.
"
" I was looking for a way to better organize my plugins and their settings and wanted to 'modularize' my
" vimrc configuration. I happened to look at Chris's vimrc in his dotfiles and it was EXACTLY what I was
" envisioning.
"
" The only addition I'm going to look to make is to look for allowing the specification of dependencies.
" Not full-blown dependency management--juts along the lines of 'this plugin requries these other plugins'.
" I'm not going to go crazy with tracking 'plugin version' dependencies. And this should only be needed in the
" case where its requried in order to set settings where plugin load ordering is important.
"
" This file contains the minimal settings to set the foundation, with the majority of the configuration
" settings living in f iles spread between .vim/rcfiles and .vim/rcplugins.

set nocompatible

" Need to set the leader before defining any leader mappings
"let mapleader = "\<Space>"

" Automatic installation of vim-plug if not found
let data_dir = has('nvim') ? stdpath('data') . '/site' : "$HOME/.vim"
if empty(glob(data_dir . '/autoload/plug.vim'))
    silent execute '!curl -fLo '.data_dir.'/autoload/plugin.vim --create-dirs https://raw.githubusercontent.junegunn/vim-plug/master/plug.vim'
    autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif

let s:autoinstall_missing_plugins = 0
if (s:autoinstall_missing_plugins)
    " Automatically install missing plugins. NOTE: This may increase vim startup time.
    autocmd VimEnter * if len(filter(values(g:plugs), '!isdirectory(v:val.dir)'))
                \ | PlugInstall --sync
                \ | source $MYVIMRC
                \ | endif
endif

