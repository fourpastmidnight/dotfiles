call s:SourceConfigFilesIn('rcplugins/polyglot.vim')
call s:SourceConfigFilesIn('rcplugins/formatting/*')
call s:SourceConfigFilesIn('rcplugins/lang/*')
call s:SourceConfigFilesIn('rcplugins/scm.vim')
call s:SourceConfigFilesIn('rcplugins/ide.vim')
call s:SourceConfigFilesIn('rcplugins/tmux.vim')
call s:SourceConfigFilesIn('rcplugins/qol.vim')

Plug 'tpope/vim-dadbod'
