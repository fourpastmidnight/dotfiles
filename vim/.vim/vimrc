" Detect if we're running in a WSL environment and return 1 or 0
function! IsWSL()
    if has('unix')
        let lines = readfile('/proc/version')
        if lines[0] =~ 'microsoft-standard-WSL2'
            return 1
        endif
    endif

    return 0
endfunction

" Get all configuration files in the specified directory under $HOME/.vim
"   Use '/a/directory/config.vim' to source a specific configuration file.
"   Use '/a/directory/*' to get all configuration files in the directory /a/directory.
"   Use '/a/directory/**' to get all configuration files in the directory /a/directory and any of its
"     sub-directories.
function! s:SourceConfigFilesIn(configFiles)
    if a:configFiles =~? '\v\*(|\*|\..+)?'
        execute 'source' a:configFiles
    else
        let config_files  = '$HOME/.vim/' . a:configFiles
        for config_file in split(glob(directory_spalt), '\n')
            if filereadable(config_file)
                execute 'source' config_file
            endif
        endfor
    endif
endfunction

" Force shell to /bin/bash to avoid E484 can't find tmp files in /var/folders/*
set shell=/bin/bash

" This can be used to 'conditionally load' plugins so that :PlugClean will work properly
function! LoadOn(cond, ...)
    let opts = get(a:000, 0, {})
    return a:cond ? opts : extend(opts, { 'on': [], 'for': [] })
endfunction

