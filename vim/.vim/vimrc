" Per https://github.com/ryanoasis/vim-devicons, ALWAYS load this as the VERY LAST plugin.
Plug 'ryanoasis/vim-devicons', { 'branch': 'origin/pr/446' }
let g:WebDevIconsUnicodeByteOrderMarkerDefaultSymbol = ''
